  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "npx nodemon start",
    "start": "node server/server.js",
    "test": "jest",
    "test:unit": "jest --runInBand --testPathPatterns=unit",
    "test:integration": "jest --runInBand --testPathPatterns='integration|app|vercel'",
    "test:coverage": "jest --runInBand --coverage",
    "test:watch": "jest --watchAll"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "accesscontrol": "^2.2.1",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.6",
    "cors": "^2.8.5",
    "cross-fetch": "^3.1.5",
    "dotenv": "^8.0.0",
    "express": "^4.22.2",
    "express-rate-limit": "^6.3.0",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^6.13.10",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nodemon": "^3.1.14",
    "swagger-jsdoc": "^6.1.0",
    "swagger-ui-express": "^4.3.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^6.0.0-alpha.7",
    "formdata-node": "^4.3.2",
    "jest": "^30.4.2",
    "mz": "^2.7.0",
    "supertest": "^6.2.2"
  },
  "jest": {
    "collectCoverageFrom": [
      "api/**/*.js",
      "config/**/*.js",
      "server/**/*.js",
      "!server/tests/**",
      "!server/util/*Data.js",
      "!server/util/grantAccess.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 75,
        "lines": 85,
        "statements": 85
      }
    }
  }
}
